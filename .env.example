API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=123456:bot_token

# Optional comma-separated Telegram user IDs for future owner-only actions.
OWNER_IDS=

# Name used internally for the default account.
DEFAULT_USER_SESSION=default

# Required for public links and invite-link private flows.
# Generate this with Kurigram/Pyrogram and keep it secret.
DEFAULT_USER_SESSION_STRING=

# Runtime paths
DB_PATH=data/forwardbot.sqlite3
SESSION_DIR=sessions
DOWNLOAD_DIR=downloads
