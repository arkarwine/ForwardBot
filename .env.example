API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=123456:bot_token

# Comma-separated Telegram user IDs allowed to use owner-only actions.
# If empty, the first user to run /start is not auto-registered; set this.
OWNER_IDS=123456789

# Session used for public links and as the default fallback account.
DEFAULT_USER_SESSION=default

# Runtime paths
DB_PATH=data/forwardbot.sqlite3
SESSION_DIR=sessions
DOWNLOAD_DIR=downloads
